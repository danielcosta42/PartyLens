# Normalize line endings: store and check out LF for text, keep binaries intact.
# Kills the "LF will be replaced by CRLF" warnings on Windows.
* text=auto eol=lf

*.lua  text eol=lf
*.toc  text eol=lf
*.md   text eol=lf
*.xml  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.pkgmeta text eol=lf
.luacheckrc text eol=lf

# Binary assets — never touch.
*.tga binary
*.blp binary
*.png binary
*.svg binary
